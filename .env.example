# ----------------------------------------------------------------
#  Выбор LLM-провайдера для AI Worker
#  Значения: routerai | gigachat
# ----------------------------------------------------------------

LLM_PROVIDER=routerai

# ----------------------------------------------------------------
#  RouterAI
# ----------------------------------------------------------------

ROUTER_AI_KEY=sk-dummy-key

# ----------------------------------------------------------------
#  GigaChat (Sber)
#  Регистрация: https://developers.sber.ru/portal/products/gigachat-api
#  В кабинете создаёшь проект и получаешь "Authorization key" —
#  одну длинную base64-строку (внутри уже зашиты Client ID и Secret).
#  Free-tier scope для физлица: GIGACHAT_API_PERS (~1М токенов/мес).
# ----------------------------------------------------------------

# GIGACHAT_AUTH_KEY=
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Сбер использует SSL-сертификат Минцифры РФ, которого нет
# в стандартном trust-store. Для dev обходим проверку:
# GIGACHAT_TRUST_ALL_CERTS=true
